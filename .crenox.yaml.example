# ─────────────────────────────────────────────────────────────────────────────
# .crenox.yaml — Crenox Pre-Commit Hook Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Place this file in your repository root OR in your home directory (~/).
# Repository-root config takes precedence over home-directory config.
# All fields are optional; omitted fields use the built-in defaults shown below.
# ─────────────────────────────────────────────────────────────────────────────

# ── Tier 2 (Entropy) Tuning ───────────────────────────────────────────────────

# Shannon entropy threshold (bits per symbol).
# Range: 0.0 to 8.0. Default: 4.5
# ↑ Raise to reduce false positives (misses more exotic secrets).
# ↓ Lower to increase sensitivity (may increase noise).
entropy_threshold: 4.5

# Minimum token length for entropy analysis.
# Tokens shorter than this are ignored — they produce noisy entropy scores.
# Default: 20
min_secret_length: 20

# ── File Processing Limits ────────────────────────────────────────────────────

# Maximum file size (in bytes) to fully scan. Files larger than this are
# skipped with a warning. Default: 10485760 (10 MB)
max_file_size_bytes: 10485760

# Set to true to also scan binary files (detected via null-byte heuristic).
# Not recommended for most projects.
# Default: false
scan_binary_files: false

# ── Path Exclusions ───────────────────────────────────────────────────────────

# Glob patterns (relative to repo root) to skip entirely.
# Supports ** for recursive matching.
#
# Note: the following directory names are ALWAYS suppressed automatically
# regardless of this list (they are treated as safe test/fixture data):
#   test, tests, testdata, fixtures, __tests__, __mocks__, mock, mocks,
#   sample, samples, docs, doc, spec, specs, seed, seeds
#
exclude_paths:
  - "vendor/**"
  - "node_modules/**"
  - "dist/**"
  - "build/**"
  - "out/**"
  - "target/**"
  - "bin/**"
  - ".next/**"
  - ".nuxt/**"
  - ".yarn/**"
  - ".git/**"
  - "*.lock"
  - "go.sum"
  - "package-lock.json"
  - "pnpm-lock.yaml"
  - "yarn.lock"
  - "**/locales/**"
  - "**/i18n/**"
  - "**/*.min.js"
  - "**/*.min.css"
  # - "path/to/safe/directory/**"

# Global allowlist for custom patterns or exact strings.
# Any finding matching these globs will be silently ignored.
allowlist_patterns:
  - "AKIAIOSFODNN7EXAMPLE"       # AWS example key (docs)
  - "*-dummy-token-*"            # generic test placeholder
  - "sk_test_*"                  # Stripe test keys
  - "lin_api_example*"           # Linear example tokens
  - "dapi_example*"              # Databricks example tokens
  - "pscale_tkn_example*"        # PlanetScale example tokens
  - "pcsk_example*"              # Pinecone example tokens
  - "railway_example*"           # Railway example tokens

# File extensions to always skip (case-insensitive).
exclude_extensions:
  - ".png"
  - ".jpg"
  - ".jpeg"
  - ".gif"
  - ".bmp"
  - ".ico"
  - ".svg"
  - ".woff"
  - ".woff2"
  - ".ttf"
  - ".eot"
  - ".mp4"
  - ".webm"
  - ".mp3"
  - ".ogg"
  - ".zip"
  - ".tar"
  - ".gz"
  - ".bz2"
  - ".xz"
  - ".7z"
  - ".pdf"
  - ".doc"
  - ".docx"
  - ".xls"
  - ".xlsx"
  - ".exe"
  - ".dll"
  - ".so"
  - ".dylib"
  - ".a"
  - ".o"
  - ".css"
  - ".scss"
  - ".csv"
  - ".hex"
  - ".pb.go"
  - ".gen.go"
  - ".g.go"
  - ".map"

# ── Tier Disabling (Advanced) ─────────────────────────────────────────────────

# Disable specific detection tiers. Use with caution.
disable_tiers:
  trie: false      # Disables Aho-Corasick pattern matching
  entropy: false   # Disables Shannon entropy analysis
  context: false   # Disables false-positive suppression (NOT recommended)

# ── Behaviour Flags ───────────────────────────────────────────────────────────

# Stop after the first finding. Useful for fast CI fail loops.
# Default: false
fail_fast: false

# Print debug information to stderr. Useful for troubleshooting exclusions.
# Default: false
verbose: false

# ─────────────────────────────────────────────────────────────────────────────
# Automatic False-Positive Suppressions (v2.1.3+, no config needed)
# ─────────────────────────────────────────────────────────────────────────────
# The following are filtered automatically without any configuration:
#
#   • Rust/C++ generic type tokens  — Option<u64>, Vec<T>, etc.
#   • Lowercase snake_case identifiers — pass_summaries, token_budget, etc.
#   • Git commit SHAs (20 or 40 hex chars) — dependency pinning references
#   • YAML/config key names without values — api-key:, auth-token:, etc.
#   • Files inside seed/ or seeds/ directories
#   • Python asyncio named parameters — return_when=asyncio.FIRST_COMPLETED
# ─────────────────────────────────────────────────────────────────────────────
