.DS_Store
Thumbs.db
.idea/
.vscode/
.cursor/
.windsurf/
.notes/
.clinerules
.cursorrules
.windsurfrules
*.swp
*.swo
*~

# Sensitive config (never commit real credentials)
.crenox.yaml
!.crenox.yaml.example

# Agent instruction cache & lockfiles
.agents/
skills-lock.json

# Cloned local repositories
nexusfi-web/


